# Cloud Run --source uploads. Unlike .gitignore, the generated demo data
# SHIPS with the image: the MCP server answers from profiles.json, and the
# demo doesn't carry GCP database credentials.
.git/
.gitignore
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
tests/
docs/
seeding/
.env
config/settings.yaml
*.pem
service-account*.json
